{
  "name": "animal-adoption-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "start:backend": "npm start -w packages/backend",
    "start:frontend": "npm run preview -w packages/frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm run build -w packages/backend",
    "build:frontend": "npm run build -w packages/frontend",
    "test:backend": "npm test -w packages/backend",
    "test:frontend": "npm test -w packages/frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "type-check": "npm run type-check -w packages/shared && npm run type-check -w packages/backend && npm run type-check -w packages/frontend"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
